# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3001    # Production: https://app.redsealion.com

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Email (optional — falls back to console logging when RESEND_API_KEY is unset)
EMAIL_PROVIDER=console
RESEND_API_KEY=
RESEND_FROM_ADDRESS=                          # Production: Your Name <noreply@yourdomain.com> (must be Resend-verified)

# Integrations — OAuth Client IDs (optional — each enables its connector)
INTEGRATION_ENCRYPTION_KEY=
ZAPIER_WEBHOOK_SECRET=
ASANA_CLIENT_ID=
CLICKUP_CLIENT_ID=
GOOGLE_CLIENT_ID=
HUBSPOT_CLIENT_ID=
MONDAY_CLIENT_ID=
PIPEDRIVE_CLIENT_ID=
SALESFORCE_CLIENT_ID=
SLACK_CLIENT_ID=
XERO_CLIENT_ID=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_SANDBOX=false

# Bluesky / AT Protocol (optional)
ATPROTO_PRIVATE_KEY=
ATPROTO_PUBLIC_KEY=

# AI Assistant (optional — degrades gracefully if not configured)
ANTHROPIC_API_KEY=

# SMS Notifications (optional — logs warning if unconfigured)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Rate Limiting (optional — falls back to in-memory store)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron (optional — used to authenticate scheduled job requests)
CRON_SECRET=

# Logging
LOG_LEVEL=info
